{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://addcommitpush.io/researcher/schemas/analysis-frontmatter.schema.json",
  "title": "Researcher Analysis Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "confidence",
    "derived_from_insights",
    "tags",
    "linked_reports",
    "transitional_scaffold",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ANL-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "disputed", "superseded"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "derived_from_insights": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^INS-[0-9]{4}$"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "linked_reports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^RPT-[0-9]{4}$"
      }
    },
    "transitional_scaffold": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
