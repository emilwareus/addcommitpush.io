{
  "$id": "https://addcommitpush.io/researcher/schemas/runtime-install.schema.json",
  "$defs": {
    "runtime_target": {
      "type": "string",
      "enum": ["codex", "claude"]
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "command_id": {
      "type": "string",
      "enum": [
        "research-new",
        "research-harvest",
        "research-refresh",
        "research-insight",
        "research-analyze",
        "research-report",
        "research-status",
        "research-resume",
        "research-update",
        "research-inspect"
      ]
    },
    "managed_asset_kind": {
      "type": "string",
      "enum": [
        "codex-skill",
        "claude-command",
        "runtime-entry",
        "runtime-core",
        "runtime-schema",
        "runtime-template",
        "runtime-settings",
        "runtime-package",
        "runtime-manifest",
        "runtime-hook"
      ]
    },
    "source_identity": {
      "type": "object",
      "required": ["version", "source_root"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source_root": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "install_request": {
      "type": "object",
      "required": [
        "runtime",
        "target_root",
        "managed_root",
        "source_identity",
        "include_optional_hooks"
      ],
      "properties": {
        "runtime": {
          "$ref": "#/$defs/runtime_target"
        },
        "target_root": {
          "type": "string",
          "minLength": 1
        },
        "managed_root": {
          "$ref": "#/$defs/relative_path"
        },
        "source_identity": {
          "$ref": "#/$defs/source_identity"
        },
        "include_optional_hooks": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "command_record": {
      "type": "object",
      "required": ["id", "installed_path", "wrapper_script_path", "payload_keys"],
      "properties": {
        "id": {
          "$ref": "#/$defs/command_id"
        },
        "installed_path": {
          "$ref": "#/$defs/relative_path"
        },
        "wrapper_script_path": {
          "$ref": "#/$defs/relative_path"
        },
        "payload_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "managed_asset_record": {
      "type": "object",
      "required": [
        "runtime",
        "kind",
        "path",
        "source_path",
        "generated_by",
        "content_hash",
        "command_ids"
      ],
      "properties": {
        "runtime": {
          "$ref": "#/$defs/runtime_target"
        },
        "kind": {
          "$ref": "#/$defs/managed_asset_kind"
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "generated_by": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "minLength": 1
        },
        "command_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/command_id"
          }
        }
      },
      "additionalProperties": false
    },
    "settings_merge_record": {
      "type": "object",
      "required": ["path", "owned_keys", "updated_at"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "owned_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "install_manifest": {
      "type": "object",
      "required": [
        "contract_version",
        "runtime",
        "managed_root",
        "generated_at",
        "source_identity",
        "commands",
        "managed_assets",
        "settings_merges"
      ],
      "properties": {
        "contract_version": {
          "type": "string",
          "const": "1.0"
        },
        "runtime": {
          "$ref": "#/$defs/runtime_target"
        },
        "managed_root": {
          "$ref": "#/$defs/relative_path"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_identity": {
          "$ref": "#/$defs/source_identity"
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_record"
          },
          "uniqueItems": true
        },
        "managed_assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/managed_asset_record"
          },
          "uniqueItems": true
        },
        "settings_merges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/settings_merge_record"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/install_request"
    },
    {
      "$ref": "#/$defs/install_manifest"
    }
  ]
}
