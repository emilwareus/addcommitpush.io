{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://addcommitpush.io/researcher/schemas/sources.schema.json",
  "title": "Researcher Source Registry",
  "type": "object",
  "required": ["research_id", "updated_at", "sources"],
  "properties": {
    "research_id": {
      "type": "string"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "url",
          "canonical_url",
          "origin",
          "type",
          "confidence",
          "status",
          "side_states",
          "published_at",
          "created_at",
          "updated_at",
          "accessed_at",
          "last_checked_at",
          "latest_capture_path",
          "captures",
          "linked_insights",
          "tags",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SRC-[0-9]{4}$"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "canonical_url": {
            "type": "string",
            "format": "uri"
          },
          "origin": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["manual", "search", "import", "agent", "other"]
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "type": {
            "type": "string",
            "enum": ["webpage", "paper", "repo", "video", "podcast", "dataset", "book", "other"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low", "unknown"]
          },
          "published_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "accessed_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "last_checked_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "read", "quoted"]
          },
          "side_states": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["rejected", "stale", "superseded"]
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "latest_capture_path": {
            "type": ["string", "null"],
            "pattern": "^data(?:\\/[^/]+)+$"
          },
          "captures": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "path", "captured_at"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["snapshot", "export", "transcript", "dataset"]
                },
                "path": {
                  "type": "string",
                  "pattern": "^data(?:\\/[^/]+)+$"
                },
                "captured_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          },
          "linked_insights": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^INS-[0-9]{4}$"
            }
          },
          "notes": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
